endpoint:
  url: "http://localhost:8000"       # Target LLM endpoint URL
  api_format: "openai"              # API format: openai | anthropic
  api_key: ""                       # API key for the LLM endpoint

dataset:
  source: "huggingface://HuggingFaceH4/ultrachat_200k"  # Dataset source: huggingface://repo or file://path
  max_samples: 1000                 # Maximum number of traces to load
  split: "train_sft"                # HuggingFace dataset split
  schema: ""                        # Dataset schema: openai_messages | sharegpt | arena (auto-detected if empty)
  hf_token: ""                      # HuggingFace token for gated/private datasets

request:
  model_override: ""                # Override model name in requests (uses trace value if empty)
  max_tokens: 256                   # Maximum tokens in LLM response
  temperature: 0.7                  # Sampling temperature (0.0–2.0)
  stream: false                     # Enable streaming responses

locust:
  users: 10                         # Number of concurrent virtual users
  spawn_rate: 2                     # Users spawned per second
  run_time: ""                      # Run duration (e.g. 5m, 1h); empty = run until stopped
